# Firebase project config (Firebase Console → Project settings → Your apps → Web app)
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_CLIENT_ID=
EXPO_PUBLIC_FIREBASE_IOS_CLIENT_ID=
EXPO_PUBLIC_FIREBASE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=

# Google OAuth client IDs (Google Cloud Console → APIs & Services → Credentials)
# Web client ID — required on Android for Google ID tokens (auto-created by Firebase)
EXPO_PUBLIC_FIREBASE_WEB_CLIENT_ID=

# Android OAuth client ID — package: com.parth_mhatre.myhealthtwin
EXPO_PUBLIC_FIREBASE_ANDROID_CLIENT_ID=

# iOS OAuth client ID — bundle ID: com.parth-mhatre.myhealthtwin
EXPO_PUBLIC_FIREBASE_IOS_CLIENT_ID=

# Digital Twin backend (FastAPI). Override per platform/target:
#   - Android emulator: http://10.0.2.2:8000  (special alias to host's localhost)
#   - iOS simulator:     http://localhost:8000
#   - Web (browser):     http://localhost:8000
#   - Physical device:   http://<your-dev-machine-LAN-IP>:8000  (same Wi-Fi)
# Leave empty to use the platform default baked into src/config/api.ts.
EXPO_PUBLIC_API_URL=

# Optional: override the request timeout (ms). Defaults to 15000.
EXPO_PUBLIC_API_TIMEOUT_MS=
