{
  "expo": {
    "name": "MyHealthtwin",
    "slug": "Frontend",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app_icon.png",
    "scheme": "myhealthtwin",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/app_icon.png",
      "bundleIdentifier": "com.parth_mhatre.myhealthtwin"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/app_icon.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.parth_mhatre.myhealthtwin"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app_icon.png"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "43b970d0-7175-4402-a60d-856b32b3fad7"
      }
    },
    "owner": "parth_mhatre"
  }
}
