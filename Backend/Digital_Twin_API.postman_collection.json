            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_message\": \"What are some healthy eating tips?\",\n  \"conversation_history\": null,\n  \"patient_data\": null,\n  \"preferred_provider\": null\n}"
            },
            "url": "{{baseUrl}}/medical-chat",
            "description": "Chat with a medical AI assistant that understands health data and can provide personalized guidance."
          }
